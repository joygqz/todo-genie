{
  "publisher": "joygqz",
  "name": "todo-genie",
  "displayName": "Todo Genie",
  "version": "2.3.0",
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f",
  "description": "Find and browse every TODO, FIXME, HACK and other comment marker across your codebase in one tree view.",
  "license": "MIT",
  "homepage": "https://github.com/joygqz/todo-genie#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/joygqz/todo-genie.git"
  },
  "bugs": {
    "url": "https://github.com/joygqz/todo-genie/issues"
  },
  "keywords": [
    "todo",
    "fixme",
    "hack",
    "comments",
    "tasks",
    "tree view",
    "productivity"
  ],
  "categories": [
    "Visualization",
    "Linters",
    "Other"
  ],
  "main": "./dist/extension.js",
  "icon": "./images/logo.png",
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "dist/*",
    "images/*"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "todo-genie",
          "title": "Todo Genie",
          "icon": "$(checklist)"
        }
      ]
    },
    "views": {
      "todo-genie": [
        {
          "id": "todo-genie.todos",
          "name": "Todos",
          "icon": "$(checklist)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "todo-genie.todos",
        "contents": "Scanning the workspace for TODO comments…",
        "when": "todo-genie.scanning"
      },
      {
        "view": "todo-genie.todos",
        "contents": "No TODO comments in the current file.\n[Show All Files](command:todo-genie.scopeAllFiles)",
        "when": "!todo-genie.scanning && todo-genie.scope == file"
      },
      {
        "view": "todo-genie.todos",
        "contents": "No TODO comments found in this workspace.\n[Refresh](command:todo-genie.refresh)",
        "when": "!todo-genie.scanning && todo-genie.scope == all"
      }
    ],
    "commands": [
      {
        "category": "Todo Genie",
        "command": "todo-genie.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "category": "Todo Genie",
        "command": "todo-genie.search",
        "title": "Search TODOs",
        "icon": "$(search)"
      },
      {
        "category": "Todo Genie",
        "command": "todo-genie.copyAll",
        "title": "Copy All as Markdown",
        "icon": "$(markdown)"
      },
      {
        "category": "Todo Genie",
        "command": "todo-genie.toggleGrouping",
        "title": "Toggle Grouping",
        "icon": "$(group-by-ref-type)"
      },
      {
        "category": "Todo Genie",
        "command": "todo-genie.scopeCurrentFile",
        "title": "Show Current File Only",
        "icon": "$(filter)"
      },
      {
        "category": "Todo Genie",
        "command": "todo-genie.scopeAllFiles",
        "title": "Show All Files",
        "icon": "$(filter-filled)"
      },
      {
        "category": "Todo Genie",
        "command": "todo-genie.collapseAll",
        "title": "Collapse All",
        "icon": "$(collapse-all)"
      },
      {
        "category": "Todo Genie",
        "command": "todo-genie.expandAll",
        "title": "Expand All",
        "icon": "$(expand-all)"
      },
      {
        "category": "Todo Genie",
        "command": "todo-genie.revealInTree",
        "title": "Reveal in Todo Genie",
        "icon": "$(list-tree)"
      },
      {
        "category": "Todo Genie",
        "command": "todo-genie.copyText",
        "title": "Copy Text",
        "icon": "$(copy)"
      },
      {
        "category": "Todo Genie",
        "command": "todo-genie.copyLocation",
        "title": "Copy Location"
      },
      {
        "category": "Todo Genie",
        "command": "todo-genie.openFile",
        "title": "Open"
      },
      {
        "category": "Todo Genie",
        "command": "todo-genie.revealInExplorer",
        "title": "Reveal in Explorer View"
      },
      {
        "category": "Todo Genie",
        "command": "todo-genie.revealFileInOS",
        "title": "Reveal in File Explorer"
      },
      {
        "category": "Todo Genie",
        "command": "todo-genie.copyPath",
        "title": "Copy Path"
      },
      {
        "category": "Todo Genie",
        "command": "todo-genie.copyRelativePath",
        "title": "Copy Relative Path"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "todo-genie.scopeCurrentFile",
          "when": "todo-genie.scope == all"
        },
        {
          "command": "todo-genie.scopeAllFiles",
          "when": "todo-genie.scope == file"
        },
        {
          "command": "todo-genie.revealInTree",
          "when": "false"
        },
        {
          "command": "todo-genie.copyText",
          "when": "false"
        },
        {
          "command": "todo-genie.copyLocation",
          "when": "false"
        },
        {
          "command": "todo-genie.openFile",
          "when": "false"
        },
        {
          "command": "todo-genie.revealInExplorer",
          "when": "false"
        },
        {
          "command": "todo-genie.revealFileInOS",
          "when": "false"
        },
        {
          "command": "todo-genie.copyPath",
          "when": "false"
        },
        {
          "command": "todo-genie.copyRelativePath",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "todo-genie.search",
          "group": "navigation@0",
          "when": "view == todo-genie.todos"
        },
        {
          "command": "todo-genie.scopeCurrentFile",
          "group": "navigation@1",
          "when": "view == todo-genie.todos && todo-genie.scope == all"
        },
        {
          "command": "todo-genie.scopeAllFiles",
          "group": "navigation@1",
          "when": "view == todo-genie.todos && todo-genie.scope == file"
        },
        {
          "command": "todo-genie.toggleGrouping",
          "group": "navigation@2",
          "when": "view == todo-genie.todos"
        },
        {
          "command": "todo-genie.refresh",
          "group": "navigation@3",
          "when": "view == todo-genie.todos"
        },
        {
          "command": "todo-genie.collapseAll",
          "group": "navigation@4",
          "when": "view == todo-genie.todos && !todo-genie.collapsed"
        },
        {
          "command": "todo-genie.expandAll",
          "group": "navigation@4",
          "when": "view == todo-genie.todos && todo-genie.collapsed"
        },
        {
          "command": "todo-genie.copyAll",
          "group": "1_actions@1",
          "when": "view == todo-genie.todos"
        }
      ],
      "view/item/context": [
        {
          "command": "todo-genie.copyText",
          "group": "9_cutcopypaste@1",
          "when": "view == todo-genie.todos && viewItem == todo"
        },
        {
          "command": "todo-genie.copyLocation",
          "group": "9_cutcopypaste@2",
          "when": "view == todo-genie.todos && viewItem == todo"
        },
        {
          "command": "todo-genie.openFile",
          "group": "navigation@1",
          "when": "view == todo-genie.todos && viewItem == file"
        },
        {
          "command": "todo-genie.revealInExplorer",
          "group": "navigation@2",
          "when": "view == todo-genie.todos && (viewItem == file || viewItem == dir)"
        },
        {
          "command": "todo-genie.revealFileInOS",
          "group": "navigation@3",
          "when": "view == todo-genie.todos && (viewItem == file || viewItem == dir)"
        },
        {
          "command": "todo-genie.copyPath",
          "group": "9_cutcopypaste@1",
          "when": "view == todo-genie.todos && (viewItem == file || viewItem == dir)"
        },
        {
          "command": "todo-genie.copyRelativePath",
          "group": "9_cutcopypaste@2",
          "when": "view == todo-genie.todos && (viewItem == file || viewItem == dir)"
        }
      ],
      "editor/context": [
        {
          "command": "todo-genie.revealInTree",
          "group": "navigation@9",
          "when": "todo-genie.onTodoLine"
        }
      ]
    },
    "configuration": {
      "title": "Todo Genie",
      "properties": {
        "todo-genie.tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "TODO",
            "FIXME",
            "HACK",
            "BUG",
            "XXX",
            "NOTE"
          ],
          "description": "Comment tags to scan for.",
          "order": 0
        },
        "todo-genie.highlight": {
          "type": "string",
          "enum": [
            "off",
            "tag",
            "line"
          ],
          "enumDescriptions": [
            "Don't highlight comment tags in the editor.",
            "Highlight only the matched tag word.",
            "Highlight from the tag to the end of the line, covering the whole comment text."
          ],
          "default": "tag",
          "description": "How to highlight matching comment tags directly in the editor.",
          "order": 1
        },
        "todo-genie.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Extra glob patterns to exclude, on top of `files.exclude` and `search.exclude`, e.g. `**/*.min.js`.",
          "order": 2
        },
        "todo-genie.tagColors": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "default": {},
          "markdownDescription": "Override the accent colour per tag with a [theme colour id](https://code.visualstudio.com/api/references/theme-color), shared by the tree and editor highlight, e.g. `{ \"TODO\": \"charts.green\", \"FIXME\": \"errorForeground\" }`. Tags left out fall back to the built-in palette.",
          "order": 3
        },
        "todo-genie.statusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show the total TODO count in the status bar.",
          "order": 4
        }
      }
    }
  },
  "scripts": {
    "prepare": "simple-git-hooks",
    "vscode:prepublish": "pnpm run package",
    "package": "pnpm run check-types && pnpm run lint && node build.js --production",
    "compile": "pnpm run check-types && pnpm run lint && node build.js",
    "watch": "run-p watch:*",
    "watch:build": "node build.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "check-types": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "ext:package": "vsce package",
    "ext:publish": "vsce publish",
    "release": "bumpp -a"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@types/node": "~24.13.2",
    "@types/vscode": "~1.90.0",
    "@vscode/vsce": "^3.9.2",
    "bumpp": "^11.1.0",
    "eslint": "^10.5.0",
    "lint-staged": "^17.0.7",
    "npm-run-all2": "^8.0.4",
    "rolldown": "^1.1.1",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "vitest": "^4.0.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run check-types && pnpm exec lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
